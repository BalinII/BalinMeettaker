{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MinuteSmith",
  "version": "0.1.9",
  "identifier": "com.srikanthnani.minutesmith",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "MinuteSmith",
        "width": 1280,
        "height": 820,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "resizable": true,
        "visibleOnAllWorkspaces": false,
        "skipTaskbar": false,
        "visible": true,
        "center": true,
        "contentProtected": false,
        "focus": true,
        "acceptFirstMouse": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": false,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "info.plist",
      "minutesmith.desktop"
    ],
    "macOS": {
      "minimumSystemVersion": "10.13"
    }
  },
  "plugins": {
    "sql": {
      "preload": [
        "sqlite:minutesmith.db"
      ]
    }
  }
}
